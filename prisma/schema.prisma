generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.1.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String                    @id @default(cuid())
  username            String                    @unique
  email               String?                   @unique
  phone               String?                   @unique
  passwordHash        String?
  name                String?                   @unique
  avatar              String?
  bio                 String?
  location            String?
  website             String?
  wechat              String?
  role                UserRole                  @default(USER)
  level               Int                       @default(1)
  verified            Boolean                   @default(false)
  verifyType          VerifyType?
  skills              String[]
  canOffer            String[]
  lookingFor          String[]
  showInPlaza         Boolean                   @default(true)
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  lastActiveAt        DateTime?
  mainTrack           String?
  mainTracks          String[]              @default([])
  startupStage        String?
  emailVerified       Boolean                   @default(false)
  emailNotifications  Boolean                   @default(true)
  onboardingCompleted Boolean                   @default(false)
  accounts            Account[]
  cityManagerProfile  CityManager?
  comments            Comment[]
  communityReviews    CommunityReview[]
  conversations       ConversationParticipant[]
  favorites           Favorite[]
  following           Follow[]                  @relation("UserFollowers")
  followers           Follow[]                  @relation("UserFollowing")
  inquiries           Inquiry[]
  sentMessages        Message[]
  notifications       Notification[]
  oneTimeTokens       OneTimeToken[]
  posts               Post[]
  progress            Progress[]                @relation("UserProgress")
  projects            Project[]
  managedCommunities  Community[]               @relation("CommunityManager")

  @@index([username])
  @@index([location])
}

model OneTimeToken {
  id        String    @id @default(cuid())
  userId    String
  type      String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId, type])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Community {
  id                String            @id @default(cuid())
  slug              String            @unique
  name              String
  city              String
  district          String?
  address           String
  latitude          Float?
  longitude         Float?
  description       String
  type              CommunityType     @default(MIXED)
  operator          String?
  contactName       String?
  contactWechat     String?
  contactPhone      String?
  website           String?
  status            CommunityStatus   @default(ACTIVE)
  featured          Boolean           @default(false)
  coverImage        String?
  images            String[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  entryFriendly     Int?
  lastVerifiedAt    DateTime?
  processTime       String?
  realTips          String[]
  benefits          Json?
  contactNote       String?
  entryInfo         Json?
  focusTracks       String[]          @default([])
  totalArea         String?
  totalWorkstations Int?
  transit           String?
  amenities         String[]          @default([])
  claims            CommunityClaim[]
  reviews           CommunityReview[]
  inquiries         Inquiry[]
  managers          User[]            @relation("CommunityManager")

  @@index([city])
  @@index([slug])
  @@index([status, featured])
}

model CommunityReview {
  id          String    @id @default(cuid())
  communityId String
  userId      String
  content     String
  difficulty  Int?
  createdAt   DateTime  @default(now())
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([communityId, userId])
  @@index([communityId])
}

model Post {
  id           String      @id @default(cuid())
  content      String
  images       String[]
  type         PostType    @default(DAILY)
  topics       String[]
  status       PostStatus  @default(PUBLISHED)
  pinned       Boolean     @default(false)
  viewCount    Int         @default(0)
  likeCount    Int         @default(0)
  commentCount Int         @default(0)
  shareCount   Int         @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  authorId     String
  budgetMax    Int?
  budgetMin    Int?
  budgetType   BudgetType?
  contactInfo  String?
  contactType  String?
  contentHtml  String?
  deadline     DateTime?
  skills       String[]
  title        String?
  milestone    String?
  projectId    String?
  comments     Comment[]
  favorites    Favorite[]
  author       User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  project      Project?    @relation(fields: [projectId], references: [id])

  @@index([authorId])
  @@index([type])
  @@index([createdAt])
  @@index([status, pinned])
  @@index([projectId, type, createdAt])
}

model Project {
  id              String        @id @default(cuid())
  slug            String        @unique
  name            String
  tagline         String?
  description     String
  logo            String?
  coverImage      String?
  images          String[]
  category        String[]
  techStack       String[]
  stage           ProjectStage  @default(IDEA)
  mrr             Int?
  userCount       Int?
  isRevenuePublic Boolean       @default(false)
  website         String?
  github          String?
  productHunt     String?
  appStore        String?
  playStore       String?
  status          ProjectStatus @default(PUBLISHED)
  featured        Boolean       @default(false)
  viewCount       Int           @default(0)
  likeCount       Int           @default(0)
  commentCount    Int           @default(0)
  launchedAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  ownerId         String
  budgetMax       Int?
  budgetMin       Int?
  budgetType      BudgetType?
  contactInfo     String?
  contactType     String?
  contentType     ContentType   @default(PROJECT)
  deadline        DateTime?
  skills          String[]
  comments        Comment[]
  favorites       Favorite[]
  posts           Post[]
  progress        Progress[]
  owner           User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([stage])
  @@index([slug])
  @@index([status, featured])
  @@index([contentType, status])
}

model Comment {
  id        String    @id @default(cuid())
  content   String
  postId    String?
  projectId String?
  parentId  String?
  authorId  String
  likeCount Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")
  post      Post?     @relation(fields: [postId], references: [id], onDelete: Cascade)
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([projectId])
  @@index([authorId])
}

model Favorite {
  id        String   @id @default(cuid())
  postId    String?
  projectId String?
  userId    String
  createdAt DateTime @default(now())
  post      Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@unique([userId, projectId])
}

model News {
  id          String       @id @default(cuid())
  title       String
  summary     String?
  content     String?
  url         String       @unique
  source      String
  category    NewsCategory
  coverImage  String?
  publishedAt DateTime
  createdAt   DateTime     @default(now())
  author      String?
  isOriginal  Boolean      @default(false)

  @@index([category])
  @@index([publishedAt])
}

model Conversation {
  id           String                    @id @default(cuid())
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  participants ConversationParticipant[]
  messages     Message[]

  @@index([updatedAt])
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  userId         String
  unreadCount    Int          @default(0)
  lastReadAt     DateTime?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt])
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model RadarItem {
  id          String      @id @default(cuid())
  title       String
  url         String      @unique
  source      String
  publishedAt DateTime?
  collectedAt DateTime    @default(now())
  summary     String?
  category    String
  city        String?
  importance  Int         @default(3)
  issueId     String?
  createdAt   DateTime    @default(now())
  eventKey    String?     @map("event_key")
  issue       RadarIssue? @relation(fields: [issueId], references: [id])

  @@index([collectedAt])
  @@index([category, city])
  @@map("radar_items")
}

model RadarIssue {
  id          String      @id @default(cuid())
  issueNo     Int         @unique
  publishedAt DateTime    @default(now())
  windowStart DateTime
  windowEnd   DateTime
  createdAt   DateTime    @default(now())
  title       String?
  summary     String?
  items       RadarItem[]

  @@map("radar_issues")
}

model RadarCbArticle {
  id          String    @id @default(cuid())
  title       String
  url         String    @unique
  used        Boolean   @default(false)
  usedAt      DateTime?
  collectedAt DateTime  @default(now())
  summary     String?

  @@map("radar_cb_articles")
}

model RadarRun {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  source    String
  collected Int      @default(0)
  skipped   Int      @default(0)
  error     String?

  @@index([createdAt])
  @@map("radar_runs")
}

model Policy {
  id        String       @id @default(cuid())
  province  String
  city      String?
  district  String?
  title     String
  summary   String
  sourceUrl String?
  status    PolicyStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([city])
  @@index([province])
  @@index([status])
}

model Inquiry {
  id              String        @id @default(cuid())
  userId          String
  communityId     String?
  communityName   String?
  name            String
  contact         String
  city            String?
  introduction    String?
  stage           String?
  wantCard        Boolean       @default(false)
  wantVerify      Boolean       @default(false)
  acceptInterview Boolean       @default(false)
  bpUrl           String?
  bpFilename      String?
  adminNote       String?
  status          InquiryStatus @default(PENDING)
  source          String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  community       Community?    @relation(fields: [communityId], references: [id])
  user            User          @relation(fields: [userId], references: [id])

  @@index([status])
  @@index([communityId])
  @@index([userId])
  @@index([userId, communityId])
  @@index([createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  content   String?
  isRead    Boolean  @default(false)
  relatedId String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
}

model CommunityClaim {
  id            String     @id @default(cuid())
  communityId   String?
  communityName String
  contactName   String
  contactInfo   String
  description   String?
  status        String     @default("PENDING")
  type          String     @default("CLAIM")
  city          String?
  createdAt     DateTime   @default(now())
  community     Community? @relation(fields: [communityId], references: [id])

  @@index([status])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("UserFollowers", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("UserFollowing", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Progress {
  id        String   @id @default(cuid())
  content   String
  milestone String?
  images    String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  authorId  String
  projectId String
  author    User     @relation("UserProgress", fields: [authorId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@index([authorId, createdAt])
}

model CityManager {
  id        String        @id @default(cuid())
  userId    String?       @unique
  name      String
  avatar    String?
  title     String?
  bio       String?
  quote     String?
  focusTags String[]      @default([])
  wechat    String?
  scope     ManagerScope  @default(CITY)
  city      String?
  province  String
  order     Int           @default(0)
  status    ManagerStatus @default(ACTIVE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  user      User?         @relation(fields: [userId], references: [id])

  @@index([status, order])
  @@index([city])
  @@index([province])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  userName   String
  userRole   String
  action     String
  targetType String
  targetId   String
  targetName String
  changes    Json?
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([targetType, targetId])
  @@index([createdAt])
}

enum UserRole {
  USER
  ADMIN
  MODERATOR
  CITY_MANAGER
}

enum ManagerScope {
  CITY
  PROVINCE
}

enum ManagerStatus {
  ACTIVE
  INACTIVE
}

enum VerifyType {
  IDENTITY
  ENTREPRENEUR
  EXPERT
  COMMUNITY
}

enum CommunityType {
  ONLINE
  OFFLINE
  MIXED
}

enum CommunityStatus {
  ACTIVE
  INACTIVE
  PENDING
}

enum PostType {
  DAILY
  EXPERIENCE
  QUESTION
  RESOURCE
  DISCUSSION
  CHAT
  HELP
  SHARE
  COLLAB
  PROGRESS
  DEMAND
}

enum PostStatus {
  DRAFT
  PUBLISHED
  HIDDEN
  DELETED
}

enum ProjectStage {
  IDEA
  BUILDING
  LAUNCHED
  REVENUE
  PROFITABLE
}

enum ProjectStatus {
  DRAFT
  PUBLISHED
  HIDDEN
  ARCHIVED
}

enum ContentType {
  PROJECT
  DEMAND
  COOPERATION
}

enum BudgetType {
  NEGOTIABLE
  FIXED
  RANGE
}

enum NewsCategory {
  POLICY
  FUNDING
  EVENT
  TECH
  STORY
  TOOL
  CASE
  REPORT
}

enum PolicyStatus {
  ACTIVE
  DRAFT
  EXPIRED
}

enum InquiryStatus {
  PENDING
  CONTACTED
  DONE
  CANCELLED
}
