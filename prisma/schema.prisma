generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.1.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String                    @id @default(cuid())
  username           String                    @unique
  email              String?                   @unique
  phone              String?                   @unique
  passwordHash       String?
  name               String?   @unique
  avatar             String?
  bio                String?
  location           String?
  website            String?
  wechat             String?
  role               UserRole                  @default(USER)
  level              Int                       @default(1)
  verified           Boolean                   @default(false)
  verifyType         VerifyType?
  skills             String[]
  canOffer           String[]
  lookingFor         String[]
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  lastActiveAt       DateTime?
  mainTrack          String?
  startupStage       String?
  emailVerified      Boolean                   @default(false)
  accounts           Account[]
  comments           Comment[]
  communityReviews   CommunityReview[]
  conversations      ConversationParticipant[]
  favorites          Favorite[]
  likes              Like[]
  sentMessages       Message[]
  posts              Post[]
  projects           Project[]
  managedCommunities Community[]               @relation("CommunityManager")
  oneTimeTokens      OneTimeToken[]

  @@index([username])
  @@index([location])
}

model OneTimeToken {
  id        String    @id @default(cuid())
  userId    String
  type      String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId, type])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Community {
  id              String            @id @default(cuid())
  slug            String            @unique
  newSlug         String?           @unique
  name            String
  city            String
  district        String?
  address         String
  latitude        Float?
  longitude       Float?
  description     String
  type            CommunityType     @default(MIXED)
  focus           String[]
  operator        String?
  contactName     String?
  contactWechat   String?
  contactPhone    String?
  website         String?
  spaceSize       String?
  workstations    Int?
  policies        Json?
  entryProcess    String[]
  services        String[]
  suitableFor     String[]
  notes           String[]
  links           Json?
  status          CommunityStatus   @default(ACTIVE)
  featured        Boolean           @default(false)
  coverImage      String?
  images          String[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  applyDifficulty Int?
  lastVerifiedAt  DateTime?
  processTime     String?
  realTips        String[]
  reviews         CommunityReview[]
  managers        User[]            @relation("CommunityManager")

  @@index([city])
  @@index([slug])
  @@index([status, featured])
}

model CommunityReview {
  id          String    @id @default(cuid())
  communityId String
  userId      String
  content     String
  difficulty  Int?
  createdAt   DateTime  @default(now())
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([communityId, userId])
  @@index([communityId])
}

model Post {
  id           String     @id @default(cuid())
  content      String
  images       String[]
  type         PostType   @default(DAILY)
  topics       String[]
  status       PostStatus @default(PUBLISHED)
  pinned       Boolean    @default(false)
  viewCount    Int        @default(0)
  likeCount    Int        @default(0)
  commentCount Int        @default(0)
  shareCount   Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  authorId     String
  comments     Comment[]
  favorites    Favorite[]
  likes        Like[]
  author       User       @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([authorId])
  @@index([type])
  @@index([createdAt])
  @@index([status, pinned])
}

model Project {
  id              String        @id @default(cuid())
  slug            String        @unique
  name            String
  tagline         String
  description     String
  logo            String?
  coverImage      String?
  screenshots     String[]
  category        String[]
  techStack       String[]
  stage           ProjectStage  @default(IDEA)
  mrr             Int?
  userCount       Int?
  isRevenuePublic Boolean       @default(false)
  website         String?
  github          String?
  productHunt     String?
  appStore        String?
  playStore       String?
  status          ProjectStatus @default(PUBLISHED)
  featured        Boolean       @default(false)
  viewCount       Int           @default(0)
  likeCount       Int           @default(0)
  commentCount    Int           @default(0)
  launchedAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  ownerId         String
  budgetMax       Int?
  budgetMin       Int?
  budgetType      BudgetType?
  contactInfo     String?
  contactType     String?
  contentType     ContentType   @default(PROJECT)
  deadline        DateTime?
  skills          String[]
  comments        Comment[]
  favorites       Favorite[]
  likes           Like[]
  owner           User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([stage])
  @@index([slug])
  @@index([status, featured])
  @@index([contentType, status])
}

model Comment {
  id        String    @id @default(cuid())
  content   String
  postId    String?
  projectId String?
  parentId  String?
  authorId  String
  likeCount Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")
  post      Post?     @relation(fields: [postId], references: [id], onDelete: Cascade)
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([projectId])
  @@index([authorId])
}

model Like {
  id        String   @id @default(cuid())
  postId    String?
  projectId String?
  userId    String
  createdAt DateTime @default(now())
  post      Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@unique([userId, projectId])
}

model Favorite {
  id        String   @id @default(cuid())
  postId    String?
  projectId String?
  userId    String
  createdAt DateTime @default(now())
  post      Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@unique([userId, projectId])
}

model News {
  id          String       @id @default(cuid())
  title       String
  summary     String?
  content     String?
  url         String       @unique
  source      String
  category    NewsCategory
  coverImage  String?
  publishedAt DateTime
  createdAt   DateTime     @default(now())
  author      String?
  isOriginal  Boolean      @default(false)

  @@index([category])
  @@index([publishedAt])
}

model Conversation {
  id           String                    @id @default(cuid())
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  participants ConversationParticipant[]
  messages     Message[]

  @@index([updatedAt])
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  userId         String
  unreadCount    Int          @default(0)
  lastReadAt     DateTime?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt])
}

enum UserRole {
  USER
  ADMIN
  MODERATOR
}

enum VerifyType {
  IDENTITY
  ENTREPRENEUR
  EXPERT
  COMMUNITY
}

enum CommunityType {
  ONLINE
  OFFLINE
  MIXED
}

enum CommunityStatus {
  ACTIVE
  INACTIVE
  PENDING
}

enum PostType {
  DAILY
  EXPERIENCE
  QUESTION
  RESOURCE
  DISCUSSION
}

enum PostStatus {
  DRAFT
  PUBLISHED
  HIDDEN
  DELETED
}

enum ProjectStage {
  IDEA
  BUILDING
  LAUNCHED
  REVENUE
  PROFITABLE
}

enum ProjectStatus {
  DRAFT
  PUBLISHED
  HIDDEN
  ARCHIVED
}

enum ContentType {
  PROJECT
  DEMAND
  COOPERATION
}

enum BudgetType {
  NEGOTIABLE
  FIXED
  RANGE
}

enum NewsCategory {
  POLICY
  FUNDING
  EVENT
  TECH
  STORY
  TOOL
  CASE
}
